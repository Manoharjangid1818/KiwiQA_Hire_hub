# ============================================================
# KiwiQA HireHub — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the real .env file to version control.
# ============================================================

# --- Database (required) ---
# Local PostgreSQL:  postgresql://USER:PASSWORD@localhost:5432/kiwiqa
# Render/Neon:       use the connection string from your cloud dashboard
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/kiwiqa

# --- Server ---
NODE_ENV=development
PORT=5000

# --- JWT Authentication (required) ---
JWT_SECRET=your-very-long-random-secret-here

# --- Email / SMTP (for OTP and password reset) ---
# For Gmail, create an App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=KiwiQA <noreply@kiwiqa.com>

# --- AI (optional — for AI question generation) ---
GEMINI_API_KEY=your-gemini-api-key
