# ============================================================
# KiwiQA HireHub — Environment Variables
# Copy this file to .env and fill in real values for local dev.
# On Render (or any cloud host), set these in the dashboard —
# do NOT commit real values to version control.
# ============================================================

# --- Database (required) ---
# Render PostgreSQL: use the "Internal Database URL" from your Render DB dashboard
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# --- Server ---
NODE_ENV=production
PORT=5000

# --- JWT Authentication (required) ---
JWT_SECRET=your-very-long-random-secret-here

# --- Email / SMTP (for OTP and password reset) ---
# For Gmail, use App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=KiwiQA <noreply@kiwiqa.com>

# --- AI (optional — for AI question generation) ---
GEMINI_API_KEY=your-gemini-api-key
