    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.19.0",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "serverless-http": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "20.19.27",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "5.6.3"
  }
